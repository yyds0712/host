---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>欢迎来到 AI with Me</h1>
				<p class="tagline">一个大学生在 AI 时代的生活记录</p>
				<p class="subtitle">这里有我用过的工具、踩过的坑、和每个普通却又值得记录的日常。</p>
			</section>
			<hr />
			<section class="latest-posts">
				<h2>最新文章</h2>
				<ul>
					{
						posts.slice(0, 3).map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h3>{post.data.title}</h3>
									<p class="date"><FormattedDate date={post.data.pubDate} /></p>
								</a>
							</li>
						))
					}
				</ul>
				<p class="more"><a href="/blog/">查看全部文章 →</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	.hero {
		text-align: center;
		padding: 2em 0;
	}
	.tagline {
		font-size: 1.5em;
		color: var(--accent);
		margin-bottom: 0.5em;
	}
	.subtitle {
		color: rgb(var(--gray));
		font-size: 1.1em;
	}
	.latest-posts ul {
		list-style: none;
		padding: 0;
	}
	.latest-posts li {
		margin-bottom: 1.5em;
	}
	.latest-posts li a {
		text-decoration: none;
	}
	.latest-posts .date {
		color: rgb(var(--gray));
		font-size: 0.9em;
		margin: 0.2em 0 0 0;
	}
	.more {
		margin-top: 2em;
	}
</style>
