---
// Twikoo comment system
// Backend: Cloudflare Workers + D1
---

<section class="twikoo-wrapper">
	<h2 class="comments-title">评论</h2>
	<div id="tcomment"></div>
</section>

<script is:inline>
	const TWIKOO_ENV_ID = 'https://twikoo.aiwithme.xyz';
	const WEBHOOK_URL = 'https://aiwithme-auto-reply.1683066.workers.dev';

	// Trigger AI reply after comment is submitted
	function triggerAIReply() {
		fetch(WEBHOOK_URL, { method: 'POST' }).catch(() => {});
	}

	// Watch for new comments via DOM changes
	const observer = new MutationObserver(() => {
		triggerAIReply();
		observer.disconnect();
	});

	// Start observing when Twikoo is initialized
	function startObserver() {
		const target = document.getElementById('tcomment');
		if (target) {
			observer.observe(target, { childList: true, subtree: true, attributes: false });
		}
	}

	// Hook into Twikoo's comment submit button
	function hookSubmitButton() {
		const checkExist = setInterval(() => {
			const btn = document.querySelector('#tcomment .el-button--primary');
			if (btn) {
				btn.addEventListener('click', () => {
					setTimeout(triggerAIReply, 3000);
				});
				clearInterval(checkExist);
			}
		}, 500);
	}

	// Init Twikoo and hooks
	twikoo.init({ envId: TWIKOO_ENV_ID, el: '#tcomment' }).then(() => {
		startObserver();
		hookSubmitButton();
	});
</script>
<script
	src="https://cdn.jsdelivr.net/npm/twikoo@1.6.41/dist/twikoo.all.min.js"
	defer
></script>

<style>
	.twikoo-wrapper {
		margin-top: 3em;
		padding-top: 2em;
		border-top: 1px solid var(--color-border);
	}
	.comments-title {
		margin-bottom: 1em;
		font-family: var(--font-heading);
	}
</style>
