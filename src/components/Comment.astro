---
// Twikoo comment system
// Backend: Cloudflare Workers + D1
---

<section class="twikoo-wrapper">
	<h2 class="comments-title">评论</h2>
	<div id="tcomment"></div>
</section>

<script is:inline>
	const TWTKOO_ENV_ID = 'https://twikoo.1683066.workers.dev';
</script>
<script
	src="https://cdn.jsdelivr.net/npm/twikoo@1.6.41/dist/twikoo.all.min.js"
	onload="twikoo.init({ envId: TWTKOO_ENV_ID, el: '#tcomment' })"
	defer
></script>

<style>
	.twikoo-wrapper {
		margin-top: 3em;
		padding-top: 2em;
		border-top: 1px solid var(--color-border);
	}
	.comments-title {
		margin-bottom: 1em;
		font-family: var(--font-heading);
	}
</style>
